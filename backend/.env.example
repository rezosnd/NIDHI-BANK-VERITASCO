# ─────────────────────────────────────────
# BACKEND ENV — Copy this file to backend/.env
# NEVER commit the real .env to GitHub!
# ─────────────────────────────────────────

PORT=5000

# PostgreSQL (Neon.tech)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# JWT Secret — change this to a long random string in production!
JWT_SECRET=change_this_to_a_long_random_secret_string_in_production

# CORS — set to your Vercel frontend URL in production
FRONTEND_URL=https://your-app.vercel.app
